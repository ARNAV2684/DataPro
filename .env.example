# Repo-root env used by docker compose for variable substitution
# (frontend build args). Copy to .env before `docker compose up --build`.
#
# Backend runtime credentials live separately in api/.env (see api/.env.example).

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
